# Public site URL (used for SEO, Open Graph, canonical links)
VITE_SITE_URL=https://ceylonclassic.com

# WhatsApp number in international format without + or spaces (e.g. 94771234567)
VITE_WHATSAPP_NUMBER=

# Contact phone (display format, e.g. +94 77 123 4567)
VITE_CONTACT_PHONE=

# Contact form — messages go to your private inbox (customers never see this address)
VITE_FORM_RECIPIENT_EMAIL=ceylon.classic.sl@gmail.com

# Optional: Web3Forms access key (https://web3forms.com) — if set, used instead of FormSubmit
VITE_WEB3FORMS_ACCESS_KEY=

# Social media profile URLs
VITE_FACEBOOK_URL=
VITE_INSTAGRAM_URL=
VITE_TIKTOK_URL=

# Google Maps embed URL (from Google Maps → Share → Embed a map)
VITE_MAP_EMBED_URL=
